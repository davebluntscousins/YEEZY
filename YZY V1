-- ============================================================
--  TAB SWITCHING
-- ============================================================
local tabFrames = {
	tools    = toolsFrame,
	players  = playersFrame,
	trolling = trollingFrame,
}

local function switchTab(tab)
	activeTab = tab
	-- hide all frames, show selected
	for k, f in pairs(tabFrames) do f.Visible = (k == tab) end
	-- update nav visual state
	for k, nav in pairs(navButtons) do
		local isActive = (k == tab)
		nav.bar.Visible = isActive
		TweenService:Create(nav.btn, TweenInfo.new(0.15), {
			BackgroundTransparency = isActive and 0 or 1,
			BackgroundColor3 = isActive and T.NavActive or T.ItemHover,
		}):Play()
		nav.icon.TextColor3 = isActive and T.Accent or T.TextMuted
		nav.name.TextColor3 = isActive and T.TextPrimary or T.TextNav
		if isActive then stroke(nav.btn, T.StrokeActive, 1) end
	end
end

