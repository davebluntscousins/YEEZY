-- GODMODE
local function startGodmode()
	godmodeActive = true; setGod(true)
	local function attachGodmode(char)
		local hum = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
		hum.MaxHealth = math.huge; hum.Health = math.huge
		hum.HealthChanged:Connect(function() if godmodeActive then hum.Health = math.huge end end)
	end
	local char = localPlayer.Character; if char then attachGodmode(char) end
	localPlayer.CharacterAdded:Connect(function(c) task.wait(0.5); if godmodeActive then attachGodmode(c) end end)
	showNotification("🛡 Godmode enabled")
end
local function stopGodmode()
	godmodeActive = false; setGod(false)
	if godmodeConn then godmodeConn:Disconnect(); godmodeConn = nil end
	showNotification("🛡 Godmode removed")
end

-- AUTO COLLECT
local function startAutoCollect()
	autoCollectConn = RunService.Heartbeat:Connect(function()
		if not autoCollectEnabled then return end
		local char = localPlayer.Character; if not char then return end
		local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and (obj.Name:lower():find("coin") or obj.Name:lower():find("gem") or obj.Name:lower():find("item")) then
				local dist = (obj.Position - hrp.Position).Magnitude
				if dist < 30 then hrp.CFrame = CFrame.new(obj.Position + Vector3.new(0,2,0)) end
			end
		end
	end)
end
local function stopAutoCollect()
	autoCollectEnabled = false
	if autoCollectConn then autoCollectConn:Disconnect(); autoCollectConn = nil end
end

-- SIT ON HEAD
local function updateSitBtn()
	if sitHeadActive then
		sitHeadBtn.Text = "Stop Sit"; sitHeadBtn.BackgroundColor3 = Color3.fromRGB(80,40,130)
		sitStatusLbl.Text = "Sitting on " .. (sitOnHeadTarget and sitOnHeadTarget.Name or "?") .. "..."
	else
		sitHeadBtn.Text = "Sit on Head"; sitHeadBtn.BackgroundColor3 = Color3.fromRGB(140,60,200)
		sitStatusLbl.Text = ""
	end
end
local function stopSitOnHead()
	sitHeadActive = false; sitOnHeadTarget = nil
	if sitOnHeadConnection then sitOnHeadConnection:Disconnect(); sitOnHeadConnection = nil end
	local char = localPlayer.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid"); if hum then hum.Sit = false end
		for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true end end
	end
	updateSitBtn()
end
local function startSitOnHead(target)
	if sitHeadActive then stopSitOnHead() end
	sitOnHeadTarget = target; sitHeadActive = true; updateSitBtn()
	sitOnHeadConnection = RunService.Heartbeat:Connect(function()
		if not sitHeadActive then return end
		local myChar = localPlayer.Character; local tChar = sitOnHeadTarget and sitOnHeadTarget.Character
		if not myChar or not tChar then return end
		local myHRP = myChar:FindFirstChild("HumanoidRootPart"); local tHead = tChar:FindFirstChild("Head")
		local myHum = myChar:FindFirstChildOfClass("Humanoid")
		if not myHRP or not tHead or not myHum then return end
		for _, p in ipairs(myChar:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
		myHRP.CFrame = tHead.CFrame * CFrame.new(0, 2.5, 0); myHum.Sit = true
	end)
end

