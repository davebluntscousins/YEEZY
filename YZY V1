-- Returns: navBtn (the clickable button), accentBar, nameLbl
local navButtons = {}  -- store for tab switching

local function makeNavItem(icon, label, tabKey)
	local wrapper = Instance.new("Frame"); wrapper.Size = UDim2.new(1, 0, 0, 36)
	wrapper.BackgroundTransparency = 1; wrapper.Parent = sideScroll

	local navBtn = Instance.new("TextButton"); navBtn.Size = UDim2.new(1, -12, 0, 32)
	navBtn.Position = UDim2.new(0, 6, 0.5, -16); navBtn.BackgroundColor3 = T.NavActive
	navBtn.BackgroundTransparency = 1; navBtn.Text = ""; navBtn.BorderSizePixel = 0
	navBtn.AutoButtonColor = false; navBtn.Parent = wrapper; corner(navBtn, 7)

	local accentBar = Instance.new("Frame"); accentBar.Size = UDim2.new(0, 3, 0.55, 0)
	accentBar.Position = UDim2.new(0, 0, 0.225, 0); accentBar.BackgroundColor3 = T.Accent
	accentBar.BorderSizePixel = 0; accentBar.Visible = false; accentBar.Parent = navBtn
	corner(accentBar, 99)

	local iconLbl = lbl(navBtn, icon, 14, T.TextMuted, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
	iconLbl.Size = UDim2.new(0, 24, 1, 0); iconLbl.Position = UDim2.new(0, 8, 0, 0)

	local nameLbl = lbl(navBtn, label, 12, T.TextNav, Enum.Font.GothamSemibold)
	nameLbl.Size = UDim2.new(1, -38, 1, 0); nameLbl.Position = UDim2.new(0, 36, 0, 0)

	navButtons[tabKey] = {btn=navBtn, bar=accentBar, icon=iconLbl, name=nameLbl}

	-- hover
	navBtn.MouseEnter:Connect(function()
		if activeTab ~= tabKey then
			TweenService:Create(navBtn, TweenInfo.new(0.12), {BackgroundTransparency=0, BackgroundColor3=T.ItemHover}):Play()
		end
	end)
	navBtn.MouseLeave:Connect(function()
		if activeTab ~= tabKey then
			TweenService:Create(navBtn, TweenInfo.new(0.12), {BackgroundTransparency=1}):Play()
		end
	end)

	return navBtn
end

