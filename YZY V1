local function showNotification(message)
	local ng = Instance.new("ScreenGui"); ng.Name = "AdminNotif"; ng.Parent = game.CoreGui
	local nf = Instance.new("Frame")
	nf.Size = UDim2.new(0, 300, 0, 48); nf.AnchorPoint = Vector2.new(0.5, 1)
	nf.Position = UDim2.new(0.5, 0, 1, -60); nf.BackgroundColor3 = T.NavActive
	nf.BorderSizePixel = 0; nf.BackgroundTransparency = 1; nf.Parent = ng
	corner(nf, 10); stroke(nf, T.StrokeActive, 1.5)
	local tl = lbl(nf, message .. " | YEEZY", 14, T.TextPrimary, Enum.Font.GothamBold)
	tl.Size = UDim2.new(1, -16, 1, 0); tl.Position = UDim2.new(0, 8, 0, 0)
	tl.TextTransparency = 1; tl.TextWrapped = true
	TweenService:Create(nf, TweenInfo.new(0.4), {BackgroundTransparency = 0}):Play()
	TweenService:Create(tl, TweenInfo.new(0.4), {TextTransparency = 0}):Play()
	task.delay(4, function()
		TweenService:Create(nf, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
		TweenService:Create(tl, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
		task.delay(0.5, function() ng:Destroy() end)
	end)
end

