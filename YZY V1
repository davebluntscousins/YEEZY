-- Toggle row (Pandora-style: icon accent bar on left, name, description, pill toggle on right)
local function makeToggle(parent, labelText, description, accentColor)
	local row = Instance.new("Frame"); row.Size = UDim2.new(1, 0, 0, 58)
	row.BackgroundColor3 = T.ItemBg; row.BorderSizePixel = 0; row.Parent = parent
	corner(row, 8); stroke(row, T.Stroke, 1)

	local bar = Instance.new("Frame"); bar.Size = UDim2.new(0, 3, 0.6, 0)
	bar.Position = UDim2.new(0, 0, 0.2, 0); bar.BackgroundColor3 = accentColor
	bar.BorderSizePixel = 0; bar.Parent = row; corner(bar, 99)

	local nameLbl = lbl(row, labelText, 13, T.TextPrimary, Enum.Font.GothamBold)
	nameLbl.Size = UDim2.new(1, -70, 0, 20); nameLbl.Position = UDim2.new(0, 14, 0, 9)

	local descLbl = lbl(row, description, 10, T.TextMuted, Enum.Font.Gotham)
	descLbl.Size = UDim2.new(1, -70, 0, 15); descLbl.Position = UDim2.new(0, 14, 0, 33)

	-- Pill toggle
	local pillBg = Instance.new("Frame"); pillBg.Size = UDim2.new(0, 42, 0, 22)
	pillBg.Position = UDim2.new(1, -52, 0.5, -11); pillBg.BackgroundColor3 = Color3.fromRGB(36, 36, 56)
	pillBg.BorderSizePixel = 0; pillBg.Parent = row; corner(pillBg, 99)

	local pill = Instance.new("Frame"); pill.Size = UDim2.new(0, 16, 0, 16)
	pill.Position = UDim2.new(0, 3, 0.5, -8); pill.BackgroundColor3 = Color3.fromRGB(90, 90, 120)
	pill.BorderSizePixel = 0; pill.Parent = pillBg; corner(pill, 99)

	local pillBtn = Instance.new("TextButton"); pillBtn.Size = UDim2.new(1, 0, 1, 0)
	pillBtn.BackgroundTransparency = 1; pillBtn.Text = ""; pillBtn.Parent = pillBg

	local function setToggle(on)
		if on then
			TweenService:Create(pillBg, TweenInfo.new(0.18), {BackgroundColor3 = accentColor}):Play()
			TweenService:Create(pill, TweenInfo.new(0.18), {Position = UDim2.new(0, 23, 0.5, -8), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
		else
			TweenService:Create(pillBg, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(36,36,56)}):Play()
			TweenService:Create(pill, TweenInfo.new(0.18), {Position = UDim2.new(0, 3, 0.5, -8), BackgroundColor3 = Color3.fromRGB(90,90,120)}):Play()
		end
	end

	return pillBtn, setToggle
end

-- Stepper row (− value +)
local function makeStepper(parent, labelText, defaultVal, fmtFn)
	local row = Instance.new("Frame"); row.Size = UDim2.new(1, 0, 0, 36)
	row.BackgroundColor3 = T.ItemBg; row.BorderSizePixel = 0; row.Parent = parent
	corner(row, 8); stroke(row, T.Stroke, 1); pad(row, 0, 0, 14, 0)

	local lbL = lbl(row, labelText, 11, T.TextMuted, Enum.Font.GothamSemibold)
	lbL.Size = UDim2.new(0.5, 0, 1, 0)

	local minus = btn(row, "−", 15, Color3.fromRGB(26, 26, 40), Enum.Font.GothamBold)
	minus.Size = UDim2.new(0, 26, 0, 26); minus.Position = UDim2.new(1, -82, 0.5, -13)
	minus.TextColor3 = T.Accent; corner(minus, 6)

	local valLbl = lbl(row, (fmtFn or tostring)(defaultVal), 11, T.TextPrimary, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
	valLbl.Size = UDim2.new(0, 36, 1, 0); valLbl.Position = UDim2.new(1, -58, 0, 0)

	local plus = btn(row, "+", 15, Color3.fromRGB(26, 26, 40), Enum.Font.GothamBold)
	plus.Size = UDim2.new(0, 26, 0, 26); plus.Position = UDim2.new(1, -28, 0.5, -13)
	plus.TextColor3 = T.Accent; corner(plus, 6)

	return minus, plus, valLbl
end

