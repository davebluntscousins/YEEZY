local function createFOVCircle()
	local circleGui = Instance.new("ScreenGui")
	circleGui.Name = "AimbotFOV"
	circleGui.ResetOnSpawn = false
	circleGui.IgnoreGuiInset = true
	circleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	circleGui.Parent = localPlayer.PlayerGui

	local circle = Instance.new("Frame")
	circle.Size = UDim2.new(0, aimbotRadius * 2, 0, aimbotRadius * 2)
	circle.Position = UDim2.new(0.5, -aimbotRadius, 0.5, -aimbotRadius)
	circle.BackgroundTransparency = 1
	circle.BorderSizePixel = 0
	circle.Parent = circleGui
	Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(255, 60, 60)
	stroke.Thickness = 1.5
	stroke.Transparency = 0
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	stroke.Parent = circle

	aimbotCircle = circle
	return circleGui
end

local function destroyFOVCircle()
	local g = localPlayer.PlayerGui:FindFirstChild("AimbotFOV")
	if g then g:Destroy() end
	aimbotCircle = nil
end

local function getScreenCenter()
	return Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
end

local function getClosestPlayerInFOV()
	local closestPlayer = nil
	local closestDist = math.huge
	local center = getScreenCenter()

	for _, player in ipairs(Players:GetPlayers()) do
		if player == localPlayer then continue end
		local char = player.Character
		if not char then continue end
		local head = char:FindFirstChild("Head")
		if not head then continue end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then continue end

		local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
		if not onScreen then continue end

		local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
		if dist <= aimbotRadius and dist < closestDist then
			closestDist = dist
			closestPlayer = player
		end
	end

	return closestPlayer
end

local function startAimbot()
	destroyFOVCircle()
	createFOVCircle()

	local lastScan = 0
	aimbotConnection = RunService.Heartbeat:Connect(function()
		if not aimbotEnabled then return end
		if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
			aimbotLockedTarget = nil
			return
		end

		-- Only scan for new target 10x per second instead of 60x to reduce lag
		local now = tick()
		if not aimbotLockedTarget or not aimbotLockedTarget.Character then
			if now - lastScan > 0.1 then
				lastScan = now
				aimbotLockedTarget = getClosestPlayerInFOV()
			end
		end

		if not aimbotLockedTarget then return end

		local char = aimbotLockedTarget.Character
		if not char then aimbotLockedTarget = nil; return end

		local head = char:FindFirstChild("Head")
		if not head then aimbotLockedTarget = nil; return end

		local screenPos, onScreen = camera:WorldToViewportPoint(head.Position)
		if not onScreen then aimbotLockedTarget = nil; return end

		local center = getScreenCenter()
		local targetScreen = Vector2.new(screenPos.X, screenPos.Y)
		if (targetScreen - center).Magnitude > aimbotRadius * 2 then
			aimbotLockedTarget = nil; return
		end

		local targetCF = CFrame.new(camera.CFrame.Position, head.Position)
		camera.CFrame = camera.CFrame:Lerp(targetCF, math.clamp(aimbotStrength, 0.01, 1))
	end)
end

local function stopAimbot()
	aimbotEnabled = false
	aimbotLockedTarget = nil
	if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
	destroyFOVCircle()
end

-- TRIGGERBOT
local function startTriggerbot()
	triggerbotConn = RunService.Heartbeat:Connect(function()
		if not triggerbotEnabled then return end
		local unitRay = camera:ScreenPointToRay(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
		local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 1000,
			RaycastParams.new())
		if result and result.Instance then
			local char = result.Instance:FindFirstAncestorOfClass("Model")
			if char then
				for _, p in ipairs(Players:GetPlayers()) do
					if p ~= localPlayer and p.Character == char then
						mouse1click(); break
					end
				end
			end
		end
	end)
end
local function stopTriggerbot()
	triggerbotEnabled = false
	if triggerbotConn then triggerbotConn:Disconnect(); triggerbotConn = nil end
end

